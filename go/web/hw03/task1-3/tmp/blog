
{{define "Blog"}}
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>Блог</title>
        <style>
            .blog {
                font-family: Arial, Helvetica, sans-serif;
            }
            .author {
                color: gray;
                font-size: 12pt;
            }
            .post {
                background-color: bisque;
                margin: 5px;
                padding: 5px;
                border-radius: 10px;
            }
            .post .text {
                margin: 5px;
                max-height: 3.25rem;
                overflow: hidden;
                text-overflow: clip;
                white-space: pre-wrap;
            }
            .post .header {
                font-weight: bold;
                color: rgb(112, 112, 112);
                border-bottom: 1px solid rgb(112, 112, 112);
                margin: 5px;
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
            }
            .post .footer {
                margin: 5px;
                color: rgb(112, 112, 112);
                font-size: 10pt;
                display: flex;
                justify-content: flex-end;
                align-items: flex-end;
            }
            .footer>*, .header>* {
                margin-right: 15px;
                white-space: nowrap;
            }
            .header .name {
                overflow: hidden;
                text-overflow: ellipsis;
            }
        </style>
    </head>
    <body>
        <div class="blog">
            <h1>{{.Name}}</h1>
            <h3 class="author">Автор: {{.Author}}</h3>

            <ul class="postList">
                {{range .Posts}}
                    {{template "Post" . }}
                {{end}}
            </ul>
        </div>
    </body>
</html>
{{end}}

{{define "Post"}}
<li class="post">
    <div class="header">
        <span class="name">{{.Name}}</span>
        <span class="createdAt">{{.CreatedAt}}</span>
    </div>
    <div class="text">{{.Text}}</div>
    <div class="footer">
        <span class="commentsCount">Комментарии: {{.GetCommentsCount}}</span>
    </div>
</li>
{{end}}